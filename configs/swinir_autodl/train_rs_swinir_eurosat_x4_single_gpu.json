{
  "task": "rs_swinir_eurosat_x4"
  , "model": "plain"
  , "gpu_ids": [0]
  , "dist": false

  , "scale": 4
  , "n_channels": 3

  , "path": {
    "root": "superresolution"
    , "pretrained_netG": null
    , "pretrained_netE": null
  }

  , "datasets": {
    "train": {
      "name": "eurosat_train"
      , "dataset_type": "sr"
      , "dataroot_H": "trainsets/remote/trainH"
      , "dataroot_L": null
      , "H_size": 64
      , "dataloader_shuffle": true
      , "dataloader_num_workers": 4
      , "dataloader_batch_size": 32
    }
    , "test": {
      "name": "eurosat_test"
      , "dataset_type": "sr"
      , "dataroot_H": "../testsets/remote/HR"
      , "dataroot_L": "../testsets/remote/LR_bicubic/X4"
    }
  }

  , "netG": {
    "net_type": "swinir"
    , "upscale": 4
    , "in_chans": 3
    , "img_size": 16
    , "window_size": 8
    , "img_range": 1.0
    , "depths": [6, 6, 6, 6]
    , "embed_dim": 60
    , "num_heads": [6, 6, 6, 6]
    , "mlp_ratio": 2
    , "upsampler": "pixelshuffledirect"
    , "resi_connection": "1conv"
    , "rs_module": true
    , "rs_module_scale": 0.1
    , "rs_module_hidden": 16
    , "init_type": "default"
    , "init_bn_type": "uniform"
    , "init_gain": 1
  }

  , "train": {
    "G_lossfn_type": "charbonnier"
    , "G_charbonnier_eps": 1e-9
    , "G_lossfn_weight": 1.0
    , "G_edge_loss_weight": 0.05
    , "G_edge_lossfn_type": "l1"
    , "G_sam_loss_weight": 0.1
    , "E_decay": 0.999
    , "G_optimizer_type": "adam"
    , "G_optimizer_lr": 2e-4
    , "G_optimizer_wd": 0
    , "G_optimizer_clipgrad": null
    , "G_optimizer_reuse": true
    , "G_scheduler_type": "MultiStepLR"
    , "G_scheduler_milestones": [20000, 40000, 60000]
    , "G_scheduler_gamma": 0.5
    , "G_regularizer_orthstep": null
    , "G_regularizer_clipstep": null
    , "G_param_strict": false
    , "E_param_strict": false
    , "checkpoint_test": 1000
    , "checkpoint_save": 1000
    , "checkpoint_print": 100
  }
}
